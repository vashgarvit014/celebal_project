# Required for embeddings and answer generation.
OPENAI_API_KEY=

# Optional but strongly recommended. Unauthenticated GitHub API calls are heavily rate limited.
GITHUB_TOKEN=

# Defaults are shown here for clarity.
PATCHCONTEXT_REPO=fastapi/fastapi
PATCHCONTEXT_RAW_DIR=data/raw
PATCHCONTEXT_PROCESSED_DIR=data/processed
PATCHCONTEXT_INDEX_DIR=indexes/fastapi
PATCHCONTEXT_EMBEDDING_MODEL=text-embedding-ada-002
PATCHCONTEXT_CHAT_MODEL=gpt-4o-mini

# Set to 1 to enable the transformers MNLI guard. If disabled/unavailable,
# PatchContext still blocks fabricated citations and unsupported source references.
PATCHCONTEXT_ENABLE_NLI=0
PATCHCONTEXT_NLI_MODEL=facebook/bart-large-mnli

